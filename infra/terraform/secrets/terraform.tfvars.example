# Template showing all required var names, empty values
# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

environment = "dev"

# Firebase
firebase_api_key             = ""
firebase_auth_domain         = ""
firebase_project_id          = ""
firebase_storage_bucket      = ""
firebase_messaging_sender_id = ""
firebase_app_id              = ""

# AWS
aws_access_key_id     = ""
aws_secret_access_key = ""
aws_s3_bucket         = ""
aws_region            = "us-east-1"

# Third-party APIs
google_vision_api_key = ""
spoonacular_api_key   = ""
openai_api_key        = ""
instacart_api_key     = ""

# App
node_env = "development"
port     = "5050"
